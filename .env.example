# OpenAI configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# LLM settings
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.8

# Database
DATABASE_URL=postgresql://infinitum:password@localhost:5432/infinitum
REDIS_URL=redis://localhost:6379

# Authentication
API_SECRET_KEY=your-secret-key

# Vector Store
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./data/chroma

# Embeddings
EMBEDDING_PROVIDER=local
